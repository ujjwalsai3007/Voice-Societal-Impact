{
  "name": "voicepay-assist",
  "version": "0.1.0",
  "description": "Voice-first financial inclusion AI agent using Vapi and Qdrant",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "load-test": "tsx scripts/load-test.ts",
    "bootstrap:vapi-tools": "tsx --env-file=.env scripts/bootstrap-vapi-tools.ts",
    "dashboard:dev": "npm run dev --prefix dashboard -- --port 3001",
    "dashboard:build": "npm run build --prefix dashboard",
    "dashboard:lint": "npm run lint --prefix dashboard"
  },
  "keywords": ["vapi", "qdrant", "voice-ai", "upi", "financial-inclusion"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@qdrant/js-client-rest": "^1.17.0",
    "hono": "^4.12.12",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
